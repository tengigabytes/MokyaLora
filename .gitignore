# KiCad auto-generated files
*.kicad_prl
*-backups/
fp-info-cache
_autosave-*

# Claude Code local settings
.claude/

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Editor temp files
*.swp
*.swo
*~
.vscode/
.idea/

# Build / firmware outputs
build/
*.elf
*.bin
*.hex
*.map
*.pio.h
*.stackdump

# Python byte-compiled
__pycache__/
*.py[cod]

# MIE generated data assets (rebuilt by tools/gen_font.py and tools/gen_dict.py)
firmware/mie/data/*.bin
firmware/mie/data/*.json

# MIE downloaded source data (fetched by tools/fetch_data.py — not committed)
firmware/mie/data_sources/

# MIE REPL runtime log
mie_repl.log

# MIE generated text data assets
firmware/mie/data/*.txt

# Bringup audio test files — WAV recordings and generated PCM C arrays may contain voice data
*.wav
firmware/tools/bringup/*_pcm.c
firmware/tools/bringup/*_pcm.h
firmware/tools/gen_voice_pcm.py

# KiCad lock files
*.lck

# Local datasheet cache (Claude Code debug reference only — not tracked)
docs/datasheet/

# Scratch / exploratory images (local-only, not part of the repo)
docs/pics/

# Temporary debug scripts
.tmp_*.ps1

# CTest/CMake test output directory (root-level, not under build/)
/Testing/

# Ad-hoc dictionary / cache analysis scratch
dict_analysis.json

# MIE test-run temp output (test_pack_dict_blob etc.)
firmware/mie/data/_test/
